{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Napas Dulu",
  "version": "1.2.0-beta",
  "identifier": "com.fk0u.napasdulu",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Napas Dulu",
        "width": 800,
        "height": 600,
        "alwaysOnTop": false,
        "fullscreen": false,
        "decorations": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "KOU & KILOUX",
    "targets": ["nsis", "msi"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
